-- INSTANT SERVER HOP - NO DELAYS
local function ServerHop()
    if not table.find(VisitedServers, game.JobId) then
        table.insert(VisitedServers, game.JobId)
    end
    
    local success, res = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100")).data
    end)
    
    if success and res then
        local possibleServers = {}
        for _, v in ipairs(res) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId and not table.find(VisitedServers, v.id) then
                table.insert(possibleServers, v.id)
            end
        end
        
        if #possibleServers > 0 then
            local target = possibleServers[math.random(1, #possibleServers)]
            table.insert(VisitedServers, target)
            TeleportService:TeleportToPlaceInstance(game.PlaceId, target)
        else
            VisitedServers = {game.JobId}
            TeleportService:Teleport(game.PlaceId)
        end
    end
end

-- OPTIMIZED VALUE PARSING
local function getVal(str)
    local clean = StripTags(str):upper():gsub(CLEAN_PATTERN, "")
    local numPart = clean:match(NUM_PATTERN)
    if not numPart then return 0 end
    local val = tonumber(numPart)
    if clean:find("T") then val = val * 1e12
    elseif clean:find("B") then val = val * 1e9
    elseif clean:find("M") then val = val * 1e6 end
    return math.floor(val or 0)
end

local function GetUnitData(label)
    local folder = label.Parent
    local brainrotName, mutationFound = "Unknown", ""
    local possibleNames = {}
    
    for _, child in ipairs(folder:GetChildren()) do
        if child:IsA("TextLabel") and child ~= label then
            local t = StripTags(child.Text)
            for _, mut in ipairs(MUTATIONS) do
                if t == mut and child.Visible and child.TextTransparency < 0.1 then
                    mutationFound = mut
                    break
                end
            end
            local bracketMatch = t:match("%b[]")
            if bracketMatch then mutationFound = bracketMatch:gsub("[%[%]]", "") end

            if Targets[Clean(t)] and brainrotName == "Unknown" then 
                brainrotName = t:gsub("%s?%b[]", "") 
            elseif not t:find("/") and not t:find("%$") and not t:match("^%d+$") and t ~= mutationFound then
                table.insert(possibleNames, t)
            end
        end
    end
    
    if brainrotName == "Unknown" then
        table.sort(possibleNames, function(a, b) return #a > #b end)
        brainrotName = possibleNames[1] or "Unknown"
    end
    
    local display = (mutationFound ~= "" and mutationFound ~= brainrotName) and ("[" .. mutationFound .. "] " .. brainrotName) or brainrotName
    return display, brainrotName
end

