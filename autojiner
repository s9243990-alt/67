-- ULTRA-FAST SCAN - IMMEDIATE HOP
local function Scan()
    local anyNew = false
    local logs = {["100M"] = {}, ["50M"] = {}, ["10M"] = {}, ["ADMIN"] = {}}

    -- SPEED: Get all descendants at once
    local allDescendants = workspace:GetDescendants()
    
    for _, v in ipairs(allDescendants) do
        if v:IsA("TextLabel") and v.Text:find("/s") then
            local val = getVal(v.Text)
            if val >= 10000000 then
                local displayTitle, searchName = GetUnitData(v)
                local tier = (val >= 100e6 and "100M") or (val >= 50e6 and "50M") or "10M"
                local key = Clean(displayTitle) .. tostring(val)
                
                if not SentUnits[key] then
                    SentUnits[key] = true
                    anyNew = true
                    local img = Images[Clean(searchName)] or ""
                    local entry = {v = val, s = "🔥 " .. displayTitle .. " " .. StripTags(v.Text), i = img, n = displayTitle}
                    table.insert(logs[tier], entry)
                    table.insert(logs["ADMIN"], entry)
                    
                    -- INSTANT LOG POST - Don't wait for webhooks
                    PostToLog(displayTitle, math.floor(val / 1000000), game.JobId)
                end
            end
        end
    end

    if anyNew then
        -- PARALLEL WEBHOOK SENDING
        for tier, data in pairs(logs) do
            if #data > 0 then
                task.spawn(function()
                    table.sort(data, function(a, b) return a.v > b.v end)
                    local list = ""
                    for _, item in ipairs(data) do list = list .. item.s .. "\n" end
                    SendWebhook((tier == "ADMIN" and ADMIN_WEBHOOK or WEBHOOKS[tier]), list, data[1].i, tier)
                end)
            end
        end
    end
    
    -- INSTANT HOP - NO DELAYS
    ServerHop()
end

