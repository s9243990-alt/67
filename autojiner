-- SPEED OPTIMIZATION: Pre-compile patterns
local STRIP_PATTERN = "<[^>]*>"
local NUM_PATTERN = "[%d%.]+"
local CLEAN_PATTERN = "[%s%,%$]"

local function Clean(t) return tostring(t):lower():gsub("%s+", ""):gsub("[%p%c%s]", "") end
local function StripTags(txt) return txt:gsub(STRIP_PATTERN, "") end

