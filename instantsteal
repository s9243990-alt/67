bindButtons = {
	instantSteal = {bind = stealBindBtn, unbind = stealUnbindBtn},
	tpBase = {bind = tpBaseBindBtn, unbind = tpBaseUnbindBtn},
	clearBase = {bind = clearBaseBindBtn, unbind = clearBaseUnbindBtn},
