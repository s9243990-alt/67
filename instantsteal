-- Función para crear botones con keybind
local function createButton(text, yPos, color)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(0, 260, 0, 32)
	container.Position = UDim2.new(0.5, -130, 0, yPos)
	container.BackgroundTransparency = 1
	container.Parent = mainFrame
	
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 160, 0, 32)
	btn.Position = UDim2.new(0, 0, 0, 0)
	btn.BackgroundColor3 = color
	btn.BorderSizePixel = 0
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 14
	btn.Parent = container
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 6)
	btnCorner.Parent = btn
	
	-- Botón para asignar keybind
	local bindBtn = Instance.new("TextButton")
	bindBtn.Size = UDim2.new(0, 45, 0, 32)
	bindBtn.Position = UDim2.new(0, 165, 0, 0)
	bindBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	bindBtn.BorderSizePixel = 0
	bindBtn.Text = "..."
	bindBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	bindBtn.Font = Enum.Font.GothamBold
	bindBtn.TextSize = 14
	bindBtn.Parent = container
	
	local bindCorner = Instance.new("UICorner")
	bindCorner.CornerRadius = UDim.new(0, 6)
	bindCorner.Parent = bindBtn
	
	-- Botón para eliminar keybind
	local unbindBtn = Instance.new("TextButton")
	unbindBtn.Size = UDim2.new(0, 45, 0, 32)
	unbindBtn.Position = UDim2.new(0, 215, 0, 0)
	unbindBtn.BackgroundColor3 = Color3.fromRGB(100, 40, 40)
	unbindBtn.BorderSizePixel = 0
	unbindBtn.Text = "X"
	unbindBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	unbindBtn.Font = Enum.Font.GothamBold
	unbindBtn.TextSize = 14
	unbindBtn.Parent = container
	
	local unbindCorner = Instance.new("UICorner")
	unbindCorner.CornerRadius = UDim.new(0, 6)
	unbindCorner.Parent = unbindBtn
	
	return btn, bindBtn, unbindBtn, container
end

