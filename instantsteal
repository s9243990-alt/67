-- Setup Booster
function setupBooster()
	if boosterConnection then
		boosterConnection:Disconnect()
	end
	
	boosterConnection = RunService.Heartbeat:Connect(function()
		if boosterEnabled then
			local char = player.Character
			if char then
				local humanoid = char:FindFirstChild("Humanoid")
				local hrp = char:FindFirstChild("HumanoidRootPart")
				
				if humanoid then
					humanoid.WalkSpeed = 75
				end
				
				if hrp then
					local bodyForce = hrp:FindFirstChild("Muhammad's Gravity")
					if not bodyForce then
						bodyForce = Instance.new("BodyForce")
						bodyForce.Name = "Muhammad's Gravity"
						bodyForce.Parent = hrp
					end
					
					local mass = hrp.AssemblyMass
					bodyForce.Force = Vector3.new(0, mass * (196.2 - 35), 0)
				end
			end
		end
	end)
end

-- Setup Noclip
function setupNoclip()
	if noclipConnection then
		noclipConnection:Disconnect()
	end
	
	noclipConnection = RunService.Stepped:Connect(function()
		if noclipEnabled then
			local char = player.Character
			if char then
				for _, part in pairs(char:GetDescendants()) do
					if part:IsA("BasePart") then
						part.CanCollide = false
					end
				end
			end
		end
	end)
end

-- Setup Infinite Jump
function setupInfiniteJump()
	if jumpConnection then
		jumpConnection:Disconnect()
	end
	
	jumpConnection = game:GetService("UserInputService").JumpRequest:Connect(function()
		if infiniteJumpEnabled then
			local char = player.Character
			if char then
				local humanoid = char:FindFirstChild("Humanoid")
				if humanoid then
					humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			end
		end
	end)
end

-- Efectos hover para botones principales
local mainButtons = {stealBtn, tpBaseBtn, clearBaseBtn, tpForwardBtn, serverHopBtn, boosterBtn, noclipBtn, infJumpBtn}
local originalColors = {
	Color3.fromRGB(200, 60, 60),
	Color3.fromRGB(60, 120, 200),
	Color3.fromRGB(180, 100, 60),
	Color3.fromRGB(120, 60, 180),
	Color3.fromRGB(220, 80, 120),
	Color3.fromRGB(100, 100, 100),
	Color3.fromRGB(100, 100, 100),
	Color3.fromRGB(100, 100, 100)
}

for i, btn in pairs(mainButtons) do
	btn.MouseEnter:Connect(function()
		if i <= 5 or (i == 6 and not boosterEnabled) or (i == 7 and not noclipEnabled) or (i == 8 and not infiniteJumpEnabled) then
			local color = originalColors[i]
			btn.BackgroundColor3 = Color3.fromRGB(
				math.min(color.R * 255 + 20, 255),
				math.min(color.G * 255 + 20, 255),
				math.min(color.B * 255 + 20, 255)
			)
		end
	end)
	
	btn.MouseLeave:Connect(function()
		if i == 6 then
			btn.BackgroundColor3 = boosterEnabled and Color3.fromRGB(60, 200, 80) or Color3.fromRGB(200, 60, 60)
		elseif i == 7 then
			btn.BackgroundColor3 = noclipEnabled and Color3.fromRGB(60, 200, 80) or Color3.fromRGB(200, 60, 60)
		elseif i == 8 then
			btn.BackgroundColor3 = infiniteJumpEnabled and Color3.fromRGB(60, 200, 80) or Color3.fromRGB(200, 60, 60)
		else
			btn.BackgroundColor3 = originalColors[i]
		end
	end)
end
