local tpBaseBtn, tpBaseBindBtn, tpBaseUnbindBtn = createButton("TP to Base", 85, Color3.fromRGB(60, 120, 200))
local clearBaseBtn, clearBaseBindBtn, clearBaseUnbindBtn = createButton("Clear Base", 125, Color3.fromRGB(180, 100, 60))
local tpForwardBtn, tpForwardBindBtn, tpForwardUnbindBtn = createButton("TP Forward", 165, Color3.fromRGB(120, 60, 180))
local serverHopBtn, serverHopBindBtn, serverHopUnbindBtn = createButton("ServerHop", 205, Color3.fromRGB(220, 80, 120))
local boosterBtn, boosterBindBtn, boosterUnbindBtn = createButton("tuff booster", 245, Color3.fromRGB(100, 100, 100))
local noclipBtn, noclipBindBtn, noclipUnbindBtn = createButton("Noclip", 285, Color3.fromRGB(100, 100, 100))
local infJumpBtn, infJumpBindBtn, infJumpUnbindBtn = createButton("Infinite Jump", 325, Color3.fromRGB(100, 100, 100))

