-- Funciones que ejecutan cada acción
local buttonFunctions = {
	instantSteal = function()
		if not savedPosition then
			stealBtn.Text = "Wait for respawn!"
			wait(0.5)
			stealBtn.Text = "Instant Steal"
			return
		end
		
		local char = player.Character
		local camera = workspace.CurrentCamera
		
		if char and char:FindFirstChild("HumanoidRootPart") then
			local hrp = char.HumanoidRootPart
			local originalCFrame = hrp.CFrame
			local originalCamCFrame = camera.CFrame
			
			camera.CameraType = Enum.CameraType.Scriptable
			camera.CFrame = originalCamCFrame
			
			hrp.CFrame = savedPosition
			wait(0.5)
			hrp.CFrame = originalCFrame
			
			camera.CameraType = Enum.CameraType.Custom
			
			stealBtn.Text = "Stolen!"
			wait(0.3)
			stealBtn.Text = "Instant Steal"
		end
	end,
	
	tpBase = function()
		if not savedPosition then
			tpBaseBtn.Text = "No base saved!"
			wait(0.5)
			tpBaseBtn.Text = "TP to Base"
			return
		end
		
		local char = player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			char.HumanoidRootPart.CFrame = savedPosition
			tpBaseBtn.Text = "Teleported!"
			wait(0.3)
			tpBaseBtn.Text = "TP to Base"
		end
	end,
	
	clearBase = function()
		local success, err = pcall(function()
			game:GetService("ReplicatedStorage"):WaitForChild("Packages"):WaitForChild("Net"):WaitForChild("RF/AdminService/ResetBrainrots"):InvokeServer()
		end)
		
		if success then
			clearBaseBtn.Text = "Base Cleared!"
			wait(0.5)
			clearBaseBtn.Text = "Clear Base"
		else
			clearBaseBtn.Text = "Error!"
			wait(0.5)
			clearBaseBtn.Text = "Clear Base"
		end
	end,
	
	tpForward = function()
		local char = player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			local hrp = char.HumanoidRootPart
			hrp.CFrame = hrp.CFrame + hrp.CFrame.LookVector * 1.4
			
			tpForwardBtn.Text = "Moved!"
			wait(0.2)
			tpForwardBtn.Text = "TP Forward"
		end
	end,
	
	serverHop = function()
		serverHopBtn.Text = "Hopping..."
		
		local success, err = pcall(function()
			local servers = {}
			local req = game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
			local body = game:GetService("HttpService"):JSONDecode(req)
			
			if body and body.data then
				for i, v in pairs(body.data) do
					if v.id ~= game.JobId and v.playing < v.maxPlayers then
						table.insert(servers, v.id)
					end
				end
			end
			
			if #servers > 0 then
				TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)])
			else
				TeleportService:Teleport(game.PlaceId)
			end
		end)
		
		if not success then
			serverHopBtn.Text = "Failed!"
			wait(1)
			serverHopBtn.Text = "ServerHop"
		end
	end,
	
	booster = function()
		boosterEnabled = not boosterEnabled
		
		if boosterEnabled then
			boosterBtn.BackgroundColor3 = Color3.fromRGB(60, 200, 80)
			setupBooster()
		else
			boosterBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
			
			if boosterConnection then
				boosterConnection:Disconnect()
			end
			
			local char = player.Character
			if char then
				local humanoid = char:FindFirstChild("Humanoid")
				local hrp = char:FindFirstChild("HumanoidRootPart")
				
				if humanoid then
					humanoid.WalkSpeed = originalWalkSpeed
				end
				
				if hrp then
					local bodyForce = hrp:FindFirstChild("Muhammad's Gravity")
					if bodyForce then
						bodyForce:Destroy()
					end
				end
			end
		end
	end,
	
	noclip = function()
		noclipEnabled = not noclipEnabled
		
		if noclipEnabled then
			noclipBtn.BackgroundColor3 = Color3.fromRGB(60, 200, 80)
			setupNoclip()
		else
			noclipBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
			
			if noclipConnection then
				noclipConnection:Disconnect()
			end
			
			local char = player.Character
			if char then
				for _, part in pairs(char:GetDescendants()) do
					if part:IsA("BasePart") then
						part.CanCollide = true
					end
				end
			end
		end
	end,
	
	infJump = function()
		infiniteJumpEnabled = not infiniteJumpEnabled
		
		if infiniteJumpEnabled then
			infJumpBtn.BackgroundColor3 = Color3.fromRGB(60, 200, 80)
			setupInfiniteJump()
		else
			infJumpBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
			
			if jumpConnection then
				jumpConnection:Disconnect()
			end
		end
	end
}

-- Sistema de keybinds
local function setupKeybind(functionName, bindBtn, unbindBtn)
	bindBtn.MouseButton1Click:Connect(function()
		waitingForKey = functionName
		bindBtn.Text = "..."
		bindBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 60)
	end)
	
	unbindBtn.MouseButton1Click:Connect(function()
		if keybinds[functionName] then
			keybinds[functionName] = nil
			bindBtn.Text = "..."
			bindBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
			unbindBtn.BackgroundColor3 = Color3.fromRGB(100, 40, 40)
		end
	end)
end

-- Configurar keybinds para cada botón
for funcName, buttons in pairs(bindButtons) do
	setupKeybind(funcName, buttons.bind, buttons.unbind)
end

-- Detectar teclas presionadas
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	-- Si estamos esperando asignar una tecla
	if waitingForKey then
		local keyName = input.KeyCode.Name
		keybinds[waitingForKey] = input.KeyCode
		
		-- Actualizar los botones correspondientes
		local buttons = bindButtons[waitingForKey]
		if buttons then
			buttons.bind.Text = keyName
			buttons.bind.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
			buttons.unbind.BackgroundColor3 = Color3.fromRGB(60, 120, 60)
		end
		
		waitingForKey = nil
		return
	end
	
	-- Ejecutar funciones según keybinds
	for funcName, keyCode in pairs(keybinds) do
		if input.KeyCode == keyCode then
			if buttonFunctions[funcName] then
				buttonFunctions[funcName]()
			end
		end
	end
end)

